@@ -962,6 +962,22 @@ namespace visage {
     resetBackingScale();
   }
 
+  IPoint WindowMac::hostContentSizePx() const {
+    // [factory patch] For an embedded plugin subview, the authoritative render size is
+    // the PARENT view's real bounds (the host's actual content area), converted to
+    // physical px with the backing scale. Logic can make this SMALLER than the size we
+    // requested via set_size when its own window chrome imposes a minimum; rendering to
+    // the request would then overflow and clip. Standalone (no parent) -> client size.
+    if (parent_view_ != nullptr) {
+      NSSize s = parent_view_.bounds.size;
+      int w = (int)std::round(s.width * backingScale());
+      int h = (int)std::round(s.height * backingScale());
+      if (w > 0 && h > 0)
+        return { w, h };
+    }
+    return { clientWidth(), clientHeight() };
+  }
+
   void WindowMac::resetBackingScale() {
     // [factory patch] Track the OS backing scale from whichever NSWindow actually hosts
     // the view. Standalone -> window_handle_; EMBEDDED plugin subview -> window_handle_
diff --git a/visage_windowing/windowing.h b/visage_windowing/windowing.h
index 8c62728..c320f10 100644
--- a/visage_windowing/windowing.h
+++ b/visage_windowing/windowing.h
@@ -140,6 +140,14 @@ namespace visage {
     // read it without a platform cast. See ui/visage/patches.
     virtual float backingScale() const { return dpiScale(); }
 
+    // [factory patch] The host-provided content area in physical px. For a standalone
+    // window this is the client size; for an EMBEDDED plugin subview WindowMac overrides
+    // it to return the PARENT view's real bounds (Logic's actual container), which can be
+    // SMALLER than the size we requested via set_size when the host's own chrome imposes a
+    // minimum — rendering to the requested size then overflows the container and clips the
+    // right + bottom. The shell renders to this instead so the editor always fits exactly.
+    virtual IPoint hostContentSizePx() const { return { client_width_, client_height_ }; }
+
     IPoint convertToNative(const Point& logical_point) const {
       return { static_cast<int>(std::round(logical_point.x * dpi_scale_)),
                static_cast<int>(std::round(logical_point.y * dpi_scale_)) };
