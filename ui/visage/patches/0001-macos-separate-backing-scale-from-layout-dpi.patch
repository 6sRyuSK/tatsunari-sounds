@@ -93,6 +93,15 @@ namespace visage {
     void handleNativeResize(int width, int height);
     bool isPopup() const { return decoration_ == Decoration::Popup; }
 
+    // [factory patch] The OS backing-store scale (points -> physical px), i.e. the
+    // NSWindow backingScaleFactor. This is SEPARATE from Window::dpiScale(): dpiScale()
+    // is the frame-tree layout scale (which an embedder may drive as a uniform zoom),
+    // whereas backingScale() is the physical pixel density the Metal layer, the
+    // drawable, and mouse point<->pixel conversions must use. When no zoom is applied
+    // the two are equal, so standalone windows are unaffected. See ui/visage/patches.
+    float backingScale() const { return backing_scale_; }
+    void setBackingScale(float scale) { backing_scale_ = scale; }
+
   private:
     static bool running_event_loop_;
     NSWindow* window_handle_ = nullptr;
@@ -101,6 +110,7 @@ namespace visage {
     VisageAppViewDelegate* view_delegate_ = nullptr;
     NSRect last_content_rect_ {};
     Decoration decoration_ = Decoration::Native;
+    float backing_scale_ = 1.0f; // [factory patch] OS backingScaleFactor; see backingScale()
   };
 }
 
